{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 38,
  "title": "CleanSpin — Store Metrics",
  "tags": ["cleanspin", "ecommerce"],
  "timezone": "browser",
  "time": { "from": "now-24h", "to": "now" },
  "refresh": "30s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Page views (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "increase(store_events_total{event=\"page_view\"}[24h])", "legendFormat": "page views" }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Sales (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "increase(store_events_total{event=\"purchase\"}[24h])", "legendFormat": "sales" }
      ],
      "options": { "colorMode": "value" }
    },
    {
      "type": "stat",
      "title": "Conversion rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "store_conversion_rate", "legendFormat": "cvr" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "stat",
      "title": "Buy-button CTR (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "increase(store_events_total{event=\"click_buy\"}[24h]) / clamp_min(increase(store_events_total{event=\"page_view\"}[24h]), 1)",
          "legendFormat": "buy ctr"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "type": "timeseries",
      "title": "Traffic over time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 5 },
      "targets": [
        { "expr": "rate(store_events_total{event=\"page_view\"}[5m])", "legendFormat": "page views/min" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Button clicks (Buy vs WhatsApp)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 5 },
      "targets": [
        { "expr": "rate(store_events_total{event=\"click_buy\"}[5m])", "legendFormat": "buy" },
        { "expr": "rate(store_events_total{event=\"click_whatsapp\"}[5m])", "legendFormat": "whatsapp" }
      ]
    },
    {
      "type": "barchart",
      "title": "Funnel — total events",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 14 },
      "targets": [
        { "expr": "sum by (event) (store_events_total)", "legendFormat": "{{event}}" }
      ]
    }
  ]
}
