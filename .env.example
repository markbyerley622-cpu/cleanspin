# Copy this file to .env and fill in your real values.
# .env is git-ignored. NEVER put real keys in this .env.example file.

# ---- Shopify cart permalink config ----
# Use the permanent .myshopify.com domain (works even with a custom domain mapped on top).
SHOPIFY_DOMAIN=your-store.myshopify.com

# Variant IDs — find in Shopify admin → Products → variant URL ends in /variants/{ID}
# If you only have ONE variant, fill in SHOPIFY_VARIANT_SINGLE and leave the others blank;
# bundles will fall back to single-variant + multiplied quantity.
SHOPIFY_VARIANT_SINGLE=
SHOPIFY_VARIANT_DOUBLE=
SHOPIFY_VARIANT_TRIPLE=

# Optional: discount code auto-applied at checkout (e.g., LAUNCH30)
SHOPIFY_DISCOUNT_CODE=

# ---- Server ----
PORT=3000
PUBLIC_URL=http://localhost:3000
